knitr::opts_chunk$set(
echo = TRUE,
message = FALSE,
warning = FALSE,
fig.width = 7,
fig.height = 5,
fig.align = "center"
)
paquetes <- c(
"tidyverse", "broom", "MASS", "glmnet", "caret", "pROC",
"modeldata", "factoextra", "cluster", "ggrepel", "knitr",
"janitor", "patchwork", "mclust"
)
instalar <- paquetes[!paquetes %in% installed.packages()[, "Package"]]
if (length(instalar) > 0) install.packages(instalar, repos = "https://cloud.r-project.org")
library(tidyverse)
library(broom)
library(MASS)        # stepAIC
library(glmnet)       # ridge / lasso
library(caret)        # particion, dummies, nearZeroVar, confusionMatrix
library(pROC)          # ROC / AUC
library(modeldata)     # dataset attrition
library(factoextra)    # PCA / clustering
library(cluster)       # silhouette
library(ggrepel)
library(knitr)
library(janitor)
library(patchwork)
theme_set(theme_minimal())
set.seed(123)
data(attrition, package = "modeldata")
dim(attrition)
glimpse(attrition)
attrition %>%
summarise(across(everything(), ~ sum(is.na(.)))) %>%
pivot_longer(everything(), names_to = "variable", values_to = "n_na") %>%
arrange(desc(n_na)) %>%
head(10) %>%
kable(caption = "Valores perdidos por variable (top 10)")
attrition %>%
count(Attrition) %>%
mutate(prop = n / sum(n)) %>%
kable(digits = 3, caption = "Distribución de Attrition")
ggplot(attrition, aes(x = Attrition, fill = Attrition)) +
geom_bar(show.legend = FALSE) +
labs(title = "Distribución de la variable respuesta", x = "Attrition", y = "Frecuencia")
set.seed(123)
idx <- createDataPartition(attrition$Attrition, p = 0.7, list = FALSE)
train <- attrition[idx, ]
test  <- attrition[-idx, ]
nrow(train); nrow(test)
prop.table(table(train$Attrition))
prop.table(table(test$Attrition))
vars_numericas <- attrition %>% select(where(is.numeric)) %>% names()
